/target
/logs

# Local operational artifacts (snapshots, archived projects) — never commit
archive/
deploy/
*.tar.gz
claudir.json
claudir-test.json
.DS_Store

# Data directories (runtime state - never commit)
data/

# Claude Code local settings (may contain API keys)
.claude/settings.local.json

# Supervisor build artifacts
supervisor/target/

# Bootstrap guardian (Phase 0) build artifacts
bootstrap-guardian/target/

# Phase 4 classifier build artifacts
tools/classify-pr/target/

# Bootstrap guardian runtime state (key, nonces, sockets, logs)
# Paths match ~/claudir-dev/run and /opt/claudir/run defaults in deploy/guardian.example.json
claudir-dev/run/
# Any guardian.json that isn't the example template
guardian.json

# Bot config files (contain tokens — never commit)
atlas.json
nova.json
security.json
nova-supervisor.json
*-supervisor.json

# Environment variables (secrets)
.env

# Voiceanon agent config files (contain bot tokens — never commit)
voiceanon/*.json

# Voiceanon runtime data (logs, sessions, SQLite databases)
voiceanon/data/
